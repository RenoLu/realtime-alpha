# realtime-alpha — optional config. Every var is OPTIONAL: if unset, that capability is
# simply off and the app runs exactly as before. Copy to .env and fill in to enable.

# --- Data layer ---------------------------------------------------------------------
# Cloudflare R2 (S3-compatible) — the Parquet lakehouse archive. All four required to enable.
RTA_R2_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
RTA_R2_BUCKET=rta-lakehouse
RTA_R2_ACCESS_KEY_ID=
RTA_R2_SECRET_ACCESS_KEY=

# Neon / Postgres — operational store (outcomes, leaderboard snapshots, model registry).
RTA_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME

# --- Model backend ------------------------------------------------------------------
# Anthropic API for the LLM strategies; or RTA_MODEL=agent for the file-backed agent model.
ANTHROPIC_API_KEY=
# RTA_MODEL=agent
# RTA_AGENT_SIGNALS=data/agent_signals.json

# --- Misc ---------------------------------------------------------------------------
# RTA_BROKERS=redpanda:9092      # set => Kafka mode; unset => embedded single-process
# RTA_SOURCE=rest                # rest (default) | ws
# RTA_ENABLE_NEWS=1              # opt-in yfinance news in the deep analyst
